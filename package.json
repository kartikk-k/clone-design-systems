{
  "name": "designgrab",
  "version": "0.1.3",
  "description": "Grab any website's design system. Capture pages, extract components, and generate a portable Tailwind component library.",
  "type": "module",
  "bin": {
    "designgrab": "dist/bin/designgrab.mjs"
  },
  "files": [
    "dist/",
    "dashboard/app.js",
    "dashboard/index.html",
    "dashboard/logo.png",
    "extension/manifest.json",
    "extension/popup.html",
    "extension/popup.js",
    "extension/icon*.png"
  ],
  "scripts": {
    "build": "bun build server.ts --target=node --outfile=dist/server.mjs && bun build bin/designgrab.ts --target=node --outfile=dist/bin/designgrab.mjs && cp scripts/prompts/agent-instructions.md dist/agent-instructions.md",
    "start": "node dist/server.mjs",
    "dev": "bun --hot server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "ui",
    "css",
    "capture",
    "chrome-extension",
    "design-grab",
    "figma",
    "design"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kartikk-k/designgrab"
  },
  "homepage": "https://designgrab.vercel.app",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
