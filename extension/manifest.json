{
  "manifest_version": 3,
  "name": "Design Grab",
  "version": "1.0",
  "description": "Grab any website's design system — sends to local server",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["capture.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
